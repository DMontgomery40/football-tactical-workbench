{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@contracts/*": ["../packages/contracts/*"]
    }
  },
  "include": ["src", "../packages/contracts/**/*.ts", "vite.config.js"]
}
